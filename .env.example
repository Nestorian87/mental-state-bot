# Telegram
TELEGRAM_BOT_TOKEN=
# Recommended for a personal bot: one Telegram user id, or comma-separated ids.
TELEGRAM_ALLOWED_USER_IDS=

# App
APP_ENV=development
APP_TIMEZONE=Europe/Kyiv
LOG_LEVEL=INFO
MEDIA_ROOT=./data/media

# Database
POSTGRES_DB=mental_state_bot
POSTGRES_USER=mental_state_bot
POSTGRES_PASSWORD=mental_state_bot
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://mental_state_bot:mental_state_bot@localhost:5433/mental_state_bot
DATABASE_SYNC_URL=postgresql+psycopg://mental_state_bot:mental_state_bot@localhost:5433/mental_state_bot

# Production image for docker-compose.prod.yml
BOT_IMAGE=ghcr.io/<owner>/mental-state-bot:latest

# Snapshot scheduling
SNAPSHOT_ACTIVE_START=09:00
SNAPSHOT_ACTIVE_END=23:30
SNAPSHOT_MIN_INTERVAL_MINUTES=30
SNAPSHOT_MAX_INTERVAL_MINUTES=70
SNAPSHOT_REMINDER_DELAY_MINUTES=25
MAX_CLARIFICATIONS_PER_SNAPSHOT=2
PHOTO_PROMPT_CHANCE=0.18

# AI chat provider. DeepSeek is OpenAI-compatible, so only base URL/model/key differ.
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_LIVE_MODEL=deepseek-v4-flash
AI_HEAVY_MODEL=deepseek-v4-pro
AI_TEMPERATURE=0.35
AI_TIMEOUT_SECONDS=45

# DeepSeek V4 thinking mode defaults to enabled, so live requests explicitly disable it.
AI_LIVE_THINKING=false
AI_HEAVY_THINKING=false
AI_PROVIDER_EXTRA_JSON={"thinking_off":{"thinking":{"type":"disabled"}},"thinking_on":{"thinking":{"type":"enabled"},"reasoning_effort":"high"}}

# Embeddings are optional for the first playable run. Keep enabled only if EMBEDDING_API_KEY is set.
EMBEDDINGS_ENABLED=true
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Telegram voice notes transcription. This is for Telegram voice messages, not audio-file uploads.
TRANSCRIPTION_ENABLED=true
TRANSCRIPTION_PROVIDER=openai
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRANSCRIPTION_LANGUAGE=uk
